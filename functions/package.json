{
  "name": "swasthya-setu-functions",
  "version": "1.0.0",
  "description": "Swasthya Setu Cloud Functions — REST API, stock prediction, redistribution, PHC health score",
  "main": "src/index.js",
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "seed": "node seed.js",
    "seed:emulator": "cross-env FIRESTORE_EMULATOR_HOST=localhost:8080 node seed.js",
    "lint": "node --check src/index.js"
  },
  "engines": {
    "node": "18"
  },
  "dependencies": {
    "@google-cloud/aiplatform": "^3.0.0",
    "@google-cloud/bigquery": "^7.9.4",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.7.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3"
  }
}
