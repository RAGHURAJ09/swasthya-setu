# ============================================================
# Cloud Functions — Environment Variables Template
# ============================================================
# For local emulator: copy to functions/.env
# For production: use `firebase functions:config:set` instead
# ============================================================

# ──── Gemini / Vertex AI ────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ──── Google Maps Distance Matrix ───────────────────────────
MAPS_API_KEY=your_google_maps_api_key_here

# ──── Twilio (SMS/WhatsApp fallback) ────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ──── Firebase Project ──────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id

# ──── Set production values via Firebase CLI ────────────────
# firebase functions:config:set gemini.key="KEY" maps.key="KEY"
# firebase functions:config:get   (to verify)
