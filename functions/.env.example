# ============================================================
# Cloud Functions — Environment Variables
# Copy to functions/.env for local emulator use
# For production: firebase functions:config:set key="val"
# ============================================================

# Gemini / Vertex AI (Module B, C, D, E, G)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key for Whisper Speech-to-Text
GROQ_API_KEY=your_groq_api_key_here

# Google Maps Distance Matrix (Module C)
MAPS_API_KEY=your_google_maps_api_key_here

# GCP API Key for Speech-to-Text, TTS, Translation (Module E)
# Same key works if all APIs are enabled on GCP project
GCP_API_KEY=your_gcp_api_key_here

# BigQuery (Module B) — uses Application Default Credentials in prod
BQ_DATASET=swasthya_setu
BQ_TABLE=stock_history

# Twilio (Module G SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Firebase Project
FIREBASE_PROJECT_ID=swasthya-setu-1969d

# ── Production setup ──────────────────────────────────────────
# firebase functions:config:set gemini.key="KEY" maps.key="KEY" gcp.key="KEY"
