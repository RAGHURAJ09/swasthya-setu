# ============================================================
# .gitattributes — Consistent line endings across all OS
# ============================================================

# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.js      text eol=lf
*.jsx     text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.json    text eol=lf
*.css     text eol=lf
*.html    text eol=lf
*.md      text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.env*    text eol=lf
*.sh      text eol=lf
*.rules   text eol=lf
*.toml    text eol=lf

# Binary files — do not modify
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.svg     binary
*.webp    binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
*.pdf     binary
*.zip     binary
*.gz      binary

# Lock files — prevent merge conflicts
package-lock.json  merge=ours
yarn.lock          merge=ours
