rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── PHC / CHC Facility profiles ─────────────────────────────────────────
    // Read: all authenticated users
    // Write: district officers or PHC staff
    match /phcs/{phcId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        (request.auth.token.role == 'officer' || request.auth.token.role == 'staff');

      // Inventory / Stock
      match /stock/{medicineId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }

      // Bed status (date-keyed documents)
      match /beds/{date} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }

      // Footfall (date-keyed documents)
      match /footfall/{date} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }

      // Staff Attendance (date-keyed documents)
      match /staffAttendance/{date} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }

      // Diagnostic Test Availability
      match /testAvailability/{testId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null &&
          (request.auth.token.role == 'officer' || request.auth.token.role == 'staff');
      }
    }

    // ── District Alerts ──────────────────────────────────────────────────────
    // Read: officers only
    // Write: Cloud Functions only (Admin SDK bypasses rules);
    //        officers can resolve (update resolved field only)
    match /districtAlerts/{alertId} {
      allow read: if request.auth != null && request.auth.token.role == 'officer';
      allow update: if request.auth != null &&
        request.auth.token.role == 'officer' &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['resolved', 'resolvedAt', 'resolvedBy', 'resolution']);
      allow create, delete: if false; // Admin SDK only
    }

    // ── Redistribution Suggestions ────────────────────────────────────────────
    match /redistributionSuggestions/{suggestionId} {
      allow read: if request.auth != null && request.auth.token.role == 'officer';
      allow update: if request.auth != null &&
        request.auth.token.role == 'officer' &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['approved', 'approvedAt', 'approvedBy']);
      allow create, delete: if false; // Admin SDK only
    }
  }
}
