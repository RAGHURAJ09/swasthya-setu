# ============================================================
# Swasthya Setu — Root .gitignore
# ============================================================

# ──── Environment & Secrets ────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.staging
*.pem
*.key
service-account.json
*-service-account*.json
firebase-adminsdk*.json

# ──── Firebase ─────────────────────────────────────────────
.firebase/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
database-debug.log
.firebaserc          # contains project ID — committed only if not sensitive

# ──── Frontend ─────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.DS_Store

# ──── Cloud Functions ───────────────────────────────────────
functions/node_modules/
functions/lib/
functions/.runtimeconfig.json   # local emulator secrets — NEVER commit

# ──── Node / npm ───────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.yarn/

# ──── Build outputs ─────────────────────────────────────────
dist/
build/
*.tgz

# ──── IDEs & editors ────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ──── OS ────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# ──── Logs ──────────────────────────────────────────────────
*.log
logs/
*.log.*

# ──── Testing ───────────────────────────────────────────────
coverage/
.nyc_output/

# ──── Misc ──────────────────────────────────────────────────
*.local
.cache/
.temp/
implementation_plan.md
smart-health-build-prompt-final.md
smart-health-build-prompt (1).md
smart-health-build-prompt.md
walkthrough.md